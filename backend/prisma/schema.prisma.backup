generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      String // "admin", "client", "mechanic", "seller"
  isActive  Boolean  @default(true)
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles     Vehicle[]
  appointments Appointment[]
  invoices     Invoice[]
  feedbacks    Feedback[]

  @@schema("public")
}

model Vehicle {
  id               String   @id @default(uuid())
  vin              String
  plate            String   @unique
  brand            String
  model            String
  year             Int
  mileage          Int
  status           String // "available", "maintenance"
  assignedClientId String?
  client           User?    @relation(fields: [assignedClientId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workOrders   WorkOrder[]
  appointments Appointment[]
  invoices     Invoice[]

  @@schema("public")
}

model Appointment {
  id          String   @id @default(uuid())
  clientId    String
  client      User     @relation(fields: [clientId], references: [id])
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  serviceType String
  date        String // YYYY-MM-DD
  time        String // HH:MM
  status      String // "scheduled", "in_progress", "completed", "cancelled"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model WorkOrder {
  id              String    @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  title           String
  description     String
  status          String // "pending", "in_progress", "completed", "cancelled"
  priority        String // "low", "medium", "high"
  reportedProblem String?
  diagnosis       String?
  repairs         String?
  workedMinutes   Int?      @default(0)
  estimatedCost   Float
  actualCost      Float?
  images          String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  usedParts WorkOrderPart[]
  feedbacks Feedback[]

  @@schema("public")
}

model InventoryItem {
  id              String   @id @default(uuid())
  name            String
  sku             String   @unique
  category        String
  quantity        Int
  minQuantity     Int
  unitPrice       Float
  supplier        String
  lastRestockDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usedInWorkOrders WorkOrderPart[]

  @@schema("public")
}

model WorkOrderPart {
  id              String        @id @default(uuid())
  workOrderId     String
  workOrder       WorkOrder     @relation(fields: [workOrderId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Int
  createdAt       DateTime      @default(now())

  @@schema("public")
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  clientId      String
  client        User     @relation(fields: [clientId], references: [id])
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  workOrderIds  String[]
  total         Float
  status        String // "draft", "sent", "paid", "overdue"
  issueDate     String
  dueDate       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items InvoiceItem[]

  @@schema("public")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Int
  unitPrice   Float
  total       Float

  @@schema("public")
}

model Feedback {
  id          String    @id @default(uuid())
  clientId    String
  client      User      @relation(fields: [clientId], references: [id])
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  rating      Int
  comment     String
  createdAt   DateTime  @default(now())

  @@schema("public")
}
